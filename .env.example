# =============================================================================
# Infantia — Variables de entorno requeridas
# Copia este archivo como .env.local y rellena los valores reales
# NUNCA commitees .env.local ni .env con valores reales
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos — Supabase PostgreSQL (con pgbouncer en transaction mode)
# Obtener en: https://supabase.com/dashboard → Project Settings → Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# -----------------------------------------------------------------------------
# Supabase Auth — SSR
# Obtener en: https://supabase.com/dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# -----------------------------------------------------------------------------
# Gemini AI (scraping NLP) — Google AI Studio
# Obtener en: https://aistudio.google.com/app/apikey
# Free tier: 20 requests/día (reset 00:00 UTC / 19:00 COL)
# -----------------------------------------------------------------------------
GOOGLE_AI_STUDIO_KEY="AIza..."

# -----------------------------------------------------------------------------
# Email — Resend
# Obtener en: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Infantia <notificaciones@infantia.co>"

# -----------------------------------------------------------------------------
# Redis — Upstash (BullMQ queue de scraping)
# Obtener en: https://console.upstash.com → Redis → Connect → ioredis
# Formato: rediss://:[password]@[host]:[port]
# -----------------------------------------------------------------------------
UPSTASH_REDIS_URL="rediss://:password@us1-example.upstash.io:6380"

# -----------------------------------------------------------------------------
# Web Push — VAPID (notificaciones push)
# Generar con: npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BN..."
VAPID_PRIVATE_KEY="..."
VAPID_SUBJECT="mailto:hola@infantia.co"

# -----------------------------------------------------------------------------
# Cron — Vercel Cron Jobs
# Generar con: openssl rand -hex 32
# Debe configurarse también en Vercel Dashboard → Settings → Environment Variables
# -----------------------------------------------------------------------------
CRON_SECRET="genera-uno-con-openssl-rand-hex-32"

# -----------------------------------------------------------------------------
# URL pública de la app
# En desarrollo: http://localhost:3000
# En producción: https://infantia-activities.vercel.app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Scraping — Proxy residencial IPRoyal (OPCIONAL)
# Plan pay-as-you-go: https://iproyal.com/residential-proxies/
# Si no se configura, el scraping funciona sin proxy (más lento, puede ser bloqueado)
# -----------------------------------------------------------------------------
# PLAYWRIGHT_PROXY_SERVER="http://geo.iproyal.com:12321"
# PLAYWRIGHT_PROXY_USER="usuario_iproyal"
# PLAYWRIGHT_PROXY_PASS="contraseña_iproyal"

# -----------------------------------------------------------------------------
# Instagram scraping (OPCIONAL)
# Credenciales de una cuenta de Instagram de prueba (no usar cuenta personal)
# -----------------------------------------------------------------------------
# IG_USERNAME="cuenta_test"
# IG_PASSWORD="contraseña_test"

# -----------------------------------------------------------------------------
# Sentry — Error tracking (OPCIONAL — free tier: 5K errores/mes)
# Obtener en: https://sentry.io → New Project → Next.js
# Sin estas vars, la app funciona normalmente pero sin error tracking
# -----------------------------------------------------------------------------
# SENTRY_DSN="https://xxx@oyyy.ingest.sentry.io/zzz"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@oyyy.ingest.sentry.io/zzz"
# SENTRY_AUTH_TOKEN="sntrys_..." # Solo si quieres source maps en Sentry
