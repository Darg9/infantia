{
  "name": "habitaplan",
  "version": "0.17.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate:brand": "node scripts/generate-brand-assets.mjs",
    "build": "npm run generate:brand && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "migrate:prod": "prisma migrate deploy",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "start:test": "next start -p 3000",
    "test:smoke": "npx playwright test --config=playwright.smoke.config.ts",
    "schema:check": "tsx scripts/check-schema.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "prepare": "husky install",
    "validate:logo": "node scripts/validate-logo.mjs",
    "ds:check": "node scripts/ds-guard.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@react-pdf/renderer": "^4.4.1",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@types/leaflet": "^1.9.21",
    "bullmq": "^5.71.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next": "^16.2.1",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-email": "^5.2.10",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "telegram": "^2.26.22",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^1.9.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.0",
    "chromatic": "^16.4.0",
    "docx": "^9.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^8.0.0",
    "jscodeshift": "^17.3.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "node-fetch": "^3.3.2",
    "sharp": "^0.33.5",
    "storybook": "^8.6.18",
    "storybook-addon-pseudo-states": "^3.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^6.4.2",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "public/logo*.{png,svg}": [
      "npm run validate:logo"
    ]
  }
}
