// =============================================================================
// Infantia - Database Schema
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Core Entities
// =============================================================================

model Activity {
  id               String           @id @default(uuid())
  title            String           @db.VarChar(255)
  description      String           @db.Text
  type             ActivityType     @default(ONE_TIME)
  status           ActivityStatus   @default(DRAFT)
  audience         ActivityAudience @default(ALL)
  startDate        DateTime?
  endDate          DateTime?
  schedule         Json? // { days: ["mon","wed"], start: "15:00", end: "17:00" }
  ageMin           Int?
  ageMax           Int?
  price            Decimal?         @db.Decimal(12, 2)
  priceCurrency    String           @default("COP") @db.VarChar(3)
  pricePeriod      PricePeriod?
  capacity         Int?
  imageUrl         String?
  providerId       String
  locationId       String?
  verticalId       String
  sourceType       SourceType       @default(MANUAL)
  sourceUrl        String?
  sourceDomain     String?          @map("source_domain") @db.VarChar(255)
  sourcePlatform   String?          @db.VarChar(50)
  sourceConfidence Float            @default(0.5)
  sourceCapturedAt DateTime?
  canonicalId      String?          @map("canonical_id")
  duplicatesCount  Int              @default(0) @map("duplicates_count")
  isVerified       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  provider   Provider           @relation(fields: [providerId], references: [id])
  location   Location?          @relation(fields: [locationId], references: [id])
  vertical   Vertical           @relation(fields: [verticalId], references: [id])
  categories ActivityCategory[]
  favorites  Favorite[]
  ratings    Rating[]
  views      ActivityView[]

  @@index([verticalId, status])
  @@index([providerId])
  @@index([locationId])
  @@index([startDate])
  @@index([status, verticalId, startDate])
  @@index([sourceDomain], map: "activities_source_domain_idx")
  @@index([canonicalId], map: "activities_canonical_id_idx")
  @@map("activities")
}

model Provider {
  id               String       @id @default(uuid())
  name             String       @db.VarChar(255)
  slug             String?      @unique @db.VarChar(100)
  type             ProviderType @default(ACADEMY)
  description      String?      @db.Text
  email            String?      @db.VarChar(255)
  phone            String?      @db.VarChar(30)
  website          String?
  instagram        String?      @db.VarChar(100)
  facebook         String?
  logoUrl          String?
  isVerified       Boolean      @default(false)
  isClaimed        Boolean      @default(false)
  isPremium        Boolean      @default(false)
  premiumSince     DateTime?
  verificationDate DateTime?
  ratingAvg        Float?
  ratingCount      Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  activities Activity[]
  locations  ProviderLocation[]
  claims     ProviderClaim[]

  @@map("providers")
}

model User {
  id                String   @id @default(uuid())
  supabaseAuthId    String   @unique @map("supabase_auth_id") @db.VarChar(255)
  email             String   @unique @db.VarChar(255)
  name              String   @db.VarChar(255)
  avatarUrl         String?
  cityId            String?
  neighborhood      String?  @db.VarChar(100)
  notificationPrefs Json     @default("{\"email\":true,\"push\":true,\"frequency\":\"daily\"}")
  onboardingDone    Boolean  @default(false)
  role              UserRole @default(PARENT)
  // Preparado para Escenario B (menores con cuenta propia) — sin lógica activa en MVP
  accountType       String   @default("adult") @db.VarChar(20) // 'adult' | 'minor'
  guardianId        String? // userId del tutor si accountType = 'minor'
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  city              City?              @relation(fields: [cityId], references: [id])
  children          Child[]
  favorites         Favorite[]
  ratings           Rating[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model Child {
  id             String   @id @default(uuid())
  userId         String
  name           String   @db.VarChar(100)
  birthDate      DateTime @db.Date
  gender         String?  @db.VarChar(20)
  interests      Json     @default("[]")
  // Consentimiento parental — Ley 1581 de 2012
  consentGivenAt DateTime
  consentGivenBy String // userId del padre/tutor que aceptó
  consentType    String   @default("parental") @db.VarChar(20) // 'parental' | 'self' (futuro Escenario B)
  consentText    String   @db.Text // texto exacto mostrado al momento del consentimiento
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("children")
}

// =============================================================================
// Geography
// =============================================================================

model City {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(100)
  countryCode String  @db.VarChar(2)
  countryName String  @db.VarChar(100)
  timezone    String  @db.VarChar(50)
  currency    String  @default("COP") @db.VarChar(3)
  isActive    Boolean @default(true)

  users           User[]
  locations       Location[]
  scrapingSources ScrapingSource[]

  @@unique([name, countryCode])
  @@map("cities")
}

model Location {
  id                        String  @id @default(uuid())
  name                      String  @db.VarChar(255)
  address                   String  @db.VarChar(500)
  neighborhood              String? @db.VarChar(100)
  cityId                    String
  latitude                  Decimal @db.Decimal(10, 8)
  longitude                 Decimal @db.Decimal(11, 8)
  isVirtual                 Boolean @default(false)
  expirationHoursAfterStart Int? // horas tras startDate para expirar si no hay endDate; null = usar config fuente o default (3h)

  city       City               @relation(fields: [cityId], references: [id])
  activities Activity[]
  providers  ProviderLocation[]
  favorites  Favorite[]

  @@index([cityId])
  @@map("locations")
}

model ProviderLocation {
  providerId String
  locationId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([providerId, locationId])
  @@map("provider_locations")
}

// =============================================================================
// Verticals & Categories
// =============================================================================

model Vertical {
  id             String  @id @default(uuid())
  slug           String  @unique @db.VarChar(50)
  name           String  @db.VarChar(100)
  description    String  @db.Text
  targetAudience String  @db.VarChar(255)
  icon           String? @db.VarChar(50)
  color          String? @db.VarChar(7)
  isActive       Boolean @default(true)
  config         Json    @default("{}")

  activities      Activity[]
  categories      Category[]
  scrapingSources ScrapingSource[]

  @@map("verticals")
}

model Category {
  id         String  @id @default(uuid())
  verticalId String
  parentId   String?
  name       String  @db.VarChar(100)
  slug       String  @db.VarChar(100)
  icon       String? @db.VarChar(50)
  sortOrder  Int     @default(0)

  vertical   Vertical           @relation(fields: [verticalId], references: [id])
  parent     Category?          @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]         @relation("CategoryTree")
  activities ActivityCategory[]

  @@unique([verticalId, slug])
  @@index([parentId])
  @@map("categories")
}

model ActivityCategory {
  activityId String
  categoryId String

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([activityId, categoryId])
  @@map("activity_categories")
}

// =============================================================================
// User Interactions
// =============================================================================

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  activityId String?
  locationId String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@unique([userId, locationId])
  @@map("favorites")
}

model Rating {
  id            String   @id @default(uuid())
  userId        String
  activityId    String
  score         Int
  comment       String?  @db.Text
  providerReply String?  @db.Text
  createdAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([activityId])
  @@map("ratings")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// =============================================================================
// Scraping
// =============================================================================

model ScrapingSource {
  id            String           @id @default(uuid())
  name          String           @db.VarChar(255)
  platform      ScrapingPlatform
  url           String
  cityId        String
  verticalId    String
  scraperType   String           @db.VarChar(50)
  scheduleCron  String           @db.VarChar(50)
  isActive      Boolean          @default(true)
  lastRunAt     DateTime?
  lastRunStatus ScrapingStatus?
  lastRunItems  Int?
  config        Json?
  notes         String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  city     City          @relation(fields: [cityId], references: [id])
  vertical Vertical      @relation(fields: [verticalId], references: [id])
  logs     ScrapingLog[]

  @@index([platform, isActive])
  @@map("scraping_sources")
}

model ScrapingLog {
  id              String         @id @default(uuid())
  sourceId        String
  startedAt       DateTime       @default(now())
  finishedAt      DateTime?
  status          ScrapingStatus @default(RUNNING)
  itemsFound      Int            @default(0)
  itemsNew        Int            @default(0)
  itemsUpdated    Int            @default(0)
  itemsDuplicated Int            @default(0)
  errorMessage    String?        @db.Text
  metadata        Json?

  source ScrapingSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
  @@map("scraping_logs")
}

model ScrapingCache {
  url       String   @id
  title     String   @db.VarChar(500)
  source    String   @db.VarChar(100)
  scrapedAt DateTime @default(now())

  @@index([source])
  @@index([scrapedAt])
  @@map("scraping_cache")
}

// =============================================================================
// Enums
// =============================================================================

enum ActivityType {
  RECURRING
  ONE_TIME
  CAMP
  WORKSHOP
}

enum ActivityAudience {
  KIDS
  FAMILY
  ADULTS
  ALL
}

enum ActivityStatus {
  ACTIVE
  PAUSED
  EXPIRED
  DRAFT
  DUPLICATE
}

enum PricePeriod {
  PER_SESSION
  MONTHLY
  TOTAL
  FREE
}

enum SourceType {
  MANUAL
  PROVIDER
  SCRAPING
}

// =============================================================================
// Analytics / Metrics
// =============================================================================

model ActivityView {
  id         String   @id @default(uuid())
  activityId String
  viewedAt   DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([viewedAt])
  @@map("activity_views")
}

model SearchLog {
  id          String   @id @default(uuid())
  query       String   @db.VarChar(300)
  resultCount Int      @default(0)
  searchedAt  DateTime @default(now())

  @@index([searchedAt])
  @@index([query])
  @@map("search_logs")
}

model ContentQualityMetric {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now()) @map("created_at")
  avgLength      Int      @map("avg_length")
  pctShort       Float    @map("pct_short")
  pctNoise       Float    @map("pct_noise")
  pctPromo       Float    @map("pct_promo")
  totalProcessed Int      @map("total_processed")
  source         String?  @map("source")
  pipelineStage  String?  @map("pipeline_stage")

  @@map("content_quality_metrics")
}

model Sponsor {
  id            String    @id @default(uuid())
  name          String    @db.VarChar(255)
  tagline       String    @db.VarChar(500)
  logoUrl       String?
  url           String
  isActive      Boolean   @default(false)
  campaignStart DateTime?
  campaignEnd   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("sponsors")
}

// =============================================================================
// Provider Claims
// =============================================================================

model ProviderClaim {
  id         String      @id @default(uuid())
  providerId String
  userId     String
  userEmail  String
  userName   String?
  message    String?
  status     ClaimStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([status])
  @@map("provider_claims")
}

// =============================================================================
// Enums (continued)
// =============================================================================

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProviderType {
  ACADEMY
  INDEPENDENT
  INSTITUTION
  GOVERNMENT
}

enum UserRole {
  PARENT
  PROVIDER
  MODERATOR
  ADMIN
}

enum ScrapingPlatform {
  WEBSITE
  INSTAGRAM
  FACEBOOK
  TELEGRAM
  TIKTOK
  X
  WHATSAPP
}

enum ScrapingStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// =============================================================================
// Source Health (Ranking Engine)
// =============================================================================

model SourceHealth {
  id            String    @id @default(uuid())
  source        String    @unique @db.VarChar(255)
  successCount  Int       @default(0) @map("success_count")
  errorCount    Int       @default(0) @map("error_count")
  lastSuccessAt DateTime? @map("last_success_at")
  lastErrorAt   DateTime? @map("last_error_at")
  avgResponseMs Int       @default(0) @map("avg_response_ms")
  score         Float     @default(1.0)
  status        String    @default("healthy") @db.VarChar(50)
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([source])
  @@index([score])
  @@map("source_health")
}

// =============================================================================
// Product Analytics (Zero Dependencies Event Tracking)
// =============================================================================

model Event {
  id         String   @id @default(uuid())
  type       String   @db.VarChar(100)
  activityId String?  @db.VarChar(255)
  path       String?  @db.Text
  metadata   Json?
  userAgent  String?  @db.Text
  ip         String?  @db.VarChar(50)
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([activityId])
  @@index([createdAt])
  @@map("events")
}
